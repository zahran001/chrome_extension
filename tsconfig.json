{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "types": ["chrome", "node"],
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
